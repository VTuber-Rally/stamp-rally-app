{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,

    "paths": {
      "~/*": ["./convex/*"],
    },
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.crypto.ts",
    "vitest.setup.ts",
    "scripts/",
  ],
}
